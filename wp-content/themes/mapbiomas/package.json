{
  "name": "nome-do-tema",
  "version": "1.0.0",
  "description": "Site Wordpress Nome do Tema",
  "license": "ISC",
  "scripts": {
    "build": "concurrently 'npm:build:*'",
    "build:css": "sass --no-source-map scss/main.scss | postcss --no-map --use autoprefixer > ./style.css",
    "build:js": "webpack --no-watch",
    "watch": "concurrently 'npm:watch:*'",
    "watch:css": "npm run build:css && chokidar 'scss/**/*.scss' --command 'npm run build:css'",
    "watch:js": "webpack --watch"
  },
  "dependencies": {
    "aos": "^2.3.4",
    "autoprefixer": "^10.4.14",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^8.2.1",
    "interactjs": "^1.10.17",
    "jquery": "^3.7.1",
    "owl.carousel": "^2.3.4",
    "postcss": "^8.4.24",
    "postcss-cli": "^10.1.0",
    "sass": "^1.60.0",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  }
}
